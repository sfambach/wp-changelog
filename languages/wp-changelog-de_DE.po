msgid "Default"
msgstr "Standard"

msgid "Stripes"
msgstr "Streifen"

msgid "Please save the post as a draft to load the history."
msgstr "Bitte speichern Sie den Beitrag als Entwurf, um die Historie zu laden."

msgid "Post created"
msgstr "Beitrag erstellt"

msgid "System"
msgstr "System"

msgid "Example: Replaced header image and updated text layout."
msgstr "Beispiel: Kopfbild ausgetauscht und Textlayout aktualisiert."

msgid "John Doe"
msgstr "John Doe"

